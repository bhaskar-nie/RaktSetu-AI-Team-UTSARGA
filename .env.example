# Lyzr API Key (required for agent calls)
LYZR_API_KEY=your-lyzr-api-key-here

# Optional: Agent ID (can also be set per-component)
AGENT_ID=your-agent-id-here

# AWS Configuration (server-side only)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# S3
AWS_S3_BUCKET=raktsetu-uploads

# SES
AWS_SES_FROM_EMAIL=noreply@yourdomain.com  # Must be a verified SES sender

# SNS
AWS_SNS_TOPIC_ARN=  # Optional, leave blank to use direct SMS publish

# Bedrock
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
